# ============================================
# AIVA Server Environment Variables
# Copy this file to .env and fill in values
# ============================================

# --- Server ---
PORT=5000
CLIENT_URL=http://localhost:3000

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Firebase Admin SDK ---
# Option A: Path to service account JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Option B: Individual values (recommended for deployment)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"

# --- Google Calendar / Meet via OAuth 2.0 (RECOMMENDED — creates real Meet links) ---
# Obtain from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Generate the refresh token via https://developers.google.com/oauthplayground
# These MUST be set BEFORE FIREBASE_PRIVATE_KEY in .env to avoid dotenv parsing issues.
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=your_oauth_refresh_token
GOOGLE_CALENDAR_ID=primary

# --- Google Calendar API (Service Account fallback — used only if OAuth vars above are missing) ---
# NOTE: Service accounts cannot create Google Meet links on consumer Gmail accounts.
GOOGLE_CALENDAR_CLIENT_EMAIL=your_calendar_service_account@your_project.iam.gserviceaccount.com
GOOGLE_CALENDAR_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_calendar_private_key_here\n-----END PRIVATE KEY-----\n"

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=your_channel_id

# --- Team Member Emails (for calendar invites) ---
TEAM_MEMBER_EMAILS=lead@example.com,dev1@example.com,dev2@example.com,tester@example.com

# --- Keep-Alive (Render free tier) ---
# Set to true on Render to prevent server from sleeping
KEEP_ALIVE=false
RENDER_EXTERNAL_URL=https://your-app.onrender.com

